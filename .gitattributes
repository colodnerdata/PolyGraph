# Set default behavior, in case people don't have core.autocrlf set.
* text=auto eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Bash scripts
*.sh text eol=lf

# Explicitly declare text files you want to always be normalized
# and checked out with LF line endings.
*.c text
*.h text
*.py text
*.md text
*.toml text
*.json text
*.yaml text
*.yml text

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.whl binary
*.pyc binary
